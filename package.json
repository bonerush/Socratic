		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^2.1.9"
	},
	"dependencies": {
		"obsidian": "latest",
		"react": "^19.2.5",
		"react-dom": "^19.2.5"
